.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Models and large outputs
*.h5
*.keras
*.pkl
*.pickle

# OS junk
Thumbs.db